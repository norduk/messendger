# SSL certificates (keep the directory, not the files)
ssl/*.crt
ssl/*.key
!ssl/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Docker volumes
postgres_data/
redis_data/
file_storage/

# Android build outputs
android/app/build/
android/.gradle/

# Capacitor
android/capacitor.settings.gradle
*.apk
