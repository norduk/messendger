# Environment variables (NEVER commit these!)
.env
.env.local
.env.production

# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
*.tgz

# Logs
logs/
*.log
npm-debug.log*

# Uploads and temporary files
uploads/*
