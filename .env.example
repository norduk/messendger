# ===========================================
# Secure Messenger - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -------------------------------------------
# SERVER CONFIGURATION
# -------------------------------------------
# Domain/IP for external access (change this to your server IP or domain)
SERVER_URL=http://192.168.1.36

# HTTP/HTTPS ports
PORT=3000
HTTPS_PORT=3443

# Admin panel port
ADMIN_PORT=3001

# Sync service port
SYNC_PORT=3002

# File service port
FILE_PORT=3003

# Node environment (development/production)
NODE_ENV=production

# -------------------------------------------
# DATABASE CONFIGURATION
# -------------------------------------------
# PostgreSQL credentials
POSTGRES_USER=messenger
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=messenger
DATABASE_URL=postgresql://messenger:CHANGE_THIS_TO_SECURE_PASSWORD@postgres:5432/messenger

# Redis credentials
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# -------------------------------------------
# SECURITY KEYS (CRITICAL - CHANGE THESE!)
# -------------------------------------------
# JWT Secret - minimum 32 characters, use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_32_CHARS

# JWT Refresh Secret - minimum 32 characters
JWT_REFRESH_SECRET=CHANGE_THIS_TO_SECURE_REFRESH_SECRET_MIN_32_CHARS

# Admin API Key - for internal container communication
ADMIN_API_KEY=CHANGE_THIS_TO_SECURE_ADMIN_API_KEY

# File Encryption Key - exactly 32 characters for AES-256
FILE_ENCRYPTION_KEY=CHANGE_THIS_TO_32_CHAR_ENCRYPTION_KEY

# -------------------------------------------
# CORS CONFIGURATION
# -------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=http://192.168.1.36:3001,http://localhost:3001,https://192.168.1.36:3443

# -------------------------------------------
# UPLOAD CONFIGURATION
# -------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=104857600

# Sync service URL (internal)
SYNC_URL=http://sync:3002

# -------------------------------------------
# ADMIN USER (Initial Setup)
# -------------------------------------------
# Default admin credentials - CHANGE AFTER FIRST LOGIN!
ADMIN_NAME=admin
ADMIN_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# -------------------------------------------
# MOBILE APP (Android)
# -------------------------------------------
# APK Server URL
APK_SERVER_URL=http://192.168.1.36
